<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ccj.campus.chat.mapper.MessageMapper">

    <!-- 基础字段映射（JSONB 字段由 TypeHandler 处理） -->
    <resultMap id="BaseResultMap" type="com.ccj.campus.chat.entity.Message">
        <id column="id" property="id"/>
        <result column="room_id" property="roomId"/>
        <result column="from_uid" property="fromUid"/>
        <result column="type" property="type"/>
        <result column="content" property="content"/>
        <result column="ext_info" property="extInfo"
                typeHandler="com.baomidou.mybatisplus.extension.handlers.JacksonTypeHandler"/>
        <result column="client_seq" property="clientSeq"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="is_visible" property="isVisible"/>
    </resultMap>

    <sql id="Base_Column_List">
        id
        , room_id, from_uid, type, content, ext_info,
        client_seq, status, create_time, is_visible
    </sql>

    <!--
      分页拉取历史消息。对齐论文 3.2 "历史消息支持分页加载"。
      使用 is_visible 部分索引加速（论文 4.2 提到的 partial index）。
    -->
    <select id="pullHistory" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM chat_message
        WHERE room_id = #{roomId}
        AND is_visible = TRUE
        <if test="cursor != null">
            AND create_time &lt; #{cursor}
        </if>
        ORDER BY create_time DESC
        LIMIT #{size}
    </select>

    <!--
      撤回消息。对齐论文 3.2：
        - 发送者自己才能撤回 (from_uid = #{uid})
        - 仅 status=0 的正常消息可被撤回（撤回时间窗由 Service 层的 2 分钟规则控制）
        - 撤回即软删除：把 content 置 NULL，ext_info 置空 JSONB
    -->
    <update id="recall">
        UPDATE chat_message
        SET status   = 1,
            content  = NULL,
            ext_info = CAST('{}' AS jsonb)
        WHERE id = #{id}
          AND from_uid = #{uid}
          AND status = 0
    </update>

</mapper>