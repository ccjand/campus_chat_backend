<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ccj.campus.chat.mapper.UserBlacklistMapper">

    <resultMap id="BaseResultMap" type="com.ccj.campus.chat.entity.UserBlacklist">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="target_id" property="targetId"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <select id="listByUser" resultMap="BaseResultMap">
        SELECT *
        FROM user_blacklist
        WHERE user_id = #{userId}
        ORDER BY create_time DESC
    </select>

    <select id="selectByUserAndTarget" resultMap="BaseResultMap">
        SELECT *
        FROM user_blacklist
        WHERE user_id = #{userId}
          AND target_id = #{targetId} LIMIT 1
    </select>

</mapper>