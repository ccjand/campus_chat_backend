<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ccj.campus.chat.mapper.LeaveApplicationMapper">

    <resultMap id="BaseResultMap" type="com.ccj.campus.chat.entity.LeaveApplication">
        <id     column="id"            property="id"/>
        <result column="applicant_id"  property="applicantId"/>
        <result column="approver_id"   property="approverId"/>
        <result column="type"          property="type"/>
        <result column="reason"        property="reason"/>
        <result column="start_time"    property="startTime"/>
        <result column="end_time"      property="endTime"/>
        <result column="attachments"   property="attachments"
                typeHandler="com.baomidou.mybatisplus.extension.handlers.JacksonTypeHandler"/>
        <result column="status"        property="status"/>
        <result column="approve_note"  property="approveNote"/>
        <result column="approve_time"  property="approveTime"/>
        <result column="card_msg_id"   property="cardMsgId"/>
        <result column="create_time"   property="createTime"/>
        <result column="update_time"   property="updateTime"/>

        <result column="applicant_name"            property="applicantName"/>
        <result column="applicant_account_number"  property="applicantAccountNumber"/>
        <result column="approver_name"             property="approverName"/>
        <result column="approver_account_number"   property="approverAccountNumber"/>
    </resultMap>

    <select id="listPendingByApprover" resultMap="BaseResultMap">
        SELECT l.*,
               a.name           AS applicant_name,
               a.account_number AS applicant_account_number,
               p.name           AS approver_name,
               p.account_number AS approver_account_number
        FROM leave_application l
                 LEFT JOIN sys_user a ON a.id = l.applicant_id
                 LEFT JOIN sys_user p ON p.id = l.approver_id
        WHERE l.approver_id = #{approverId}
          AND l.status = 0
        ORDER BY l.create_time DESC
    </select>

    <select id="listByApplicant" resultMap="BaseResultMap">
        SELECT l.*,
               a.name           AS applicant_name,
               a.account_number AS applicant_account_number,
               p.name           AS approver_name,
               p.account_number AS approver_account_number
        FROM leave_application l
                 LEFT JOIN sys_user a ON a.id = l.applicant_id
                 LEFT JOIN sys_user p ON p.id = l.approver_id
        WHERE l.applicant_id = #{applicantId}
        ORDER BY l.create_time DESC
    </select>
</mapper>