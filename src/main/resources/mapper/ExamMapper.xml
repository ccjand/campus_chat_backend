<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ccj.campus.chat.mapper.ExamMapper">

    <resultMap id="BaseResultMap" type="com.ccj.campus.chat.entity.Exam">
        <id column="id" property="id"/>
        <result column="class_id" property="classId"/>
        <result column="name" property="name"/>
        <result column="exam_time" property="examTime"/>
        <result column="duration_minutes" property="durationMinutes"/>
        <result column="location" property="location"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <!-- 对齐论文 3.2："学生可在应用内查询本人的考试安排" -->
    <select id="listByStudent" resultMap="BaseResultMap">
        SELECT e.*
        FROM exam e
                 JOIN sys_user_class_rel ucr ON ucr.class_id = e.class_id
        WHERE ucr.user_id = #{studentId}
        ORDER BY e.exam_time ASC
    </select>

</mapper>